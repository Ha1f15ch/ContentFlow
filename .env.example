# =============================================================================
# ContentFlow — Docker Compose environment
# Copy to .env and adjust values:  cp .env.example .env
# =============================================================================

COMPOSE_PROJECT_NAME=contentflow

# Port on your machine -> nginx inside container
HTTP_PORT=8080

# Optional: expose API directly (Swagger, debugging). Leave empty to disable.
# Example: 8081
API_EXPOSE_PORT=8081

# SQL Server on localhost for DBeaver (1433 often taken by local SQL Server on Windows)
DB_EXPOSE_PORT=14333

# Public URLs (what the browser uses)
PUBLIC_BASE_URL=http://localhost:8080
PUBLIC_API_URL=http://localhost:8080/api

# Comma-separated CORS origins
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# SQL Server (container name "db" inside Docker network)
DB_HOST=db
DB_PORT=1433
DB_NAME=ContentFlow
DB_USER=sa
DB_PASSWORD=ContentFlow_StrongPass123!
MSSQL_PID=Express

# API
API_INTERNAL_PORT=8080
ASPNETCORE_ENVIRONMENT=Development
RUNNING_IN_DOCKER=true
BEHIND_REVERSE_PROXY=true

JWT_SECRET=replace_with_at_least_32_bytes_secret_key_123456
JWT_ISSUER=contentflow-api
JWT_AUDIENCE=contentflow-client
JWT_EXPIRES_MINUTES=30

# Email (optional for local testing)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Frontend build-time API path (relative = same origin via nginx)
VITE_API_BASE_URL=/api
